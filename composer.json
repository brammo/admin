{
    "name": "brammo/admin",
    "description": "Admin dashboard plugin for CakePHP",
    "type": "cakephp-plugin",
    "keywords": [
        "cakephp", 
        "plugin", 
        "admin",
        "dashboard"
    ],
    "homepage": "https://github.com/brammo/admin",
    "authors": [
        {
            "name": "Roman Sidorkin",
            "email": "roman.sidorkin@gmail.com"
        }
    ],
    "license": "MIT",
    "version": "1.1.0",
    "prefer-stable": true,
    "require": {
        "php": ">=8.1",
        "cakephp/cakephp": "^5.3",
        "friendsofcake/bootstrap-ui": "^5.0",
        "brammo/bootstrap-ui": "^1.0",
        "brammo/content": "^1.0",
        "brammo/auth": "^1.1"
    },
    "require-dev": {
        "cakephp/bake": "^3.0.0",
        "cakephp/cakephp-codesniffer": "^5.3",
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^2.1",
        "vimeo/psalm": "^5.26"
    },
    "autoload": {
        "psr-4": {
            "Brammo\\Admin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Brammo\\Admin\\Test\\": "tests/"
        }
    },
    "scripts": {
        "check": [
            "@test",
            "@cs-check"
        ],
        "analyse": [
            "@stan",
            "@psalm"
         ],
        "cs-check": "phpcs --colors -p src tests",
        "cs-fix": "phpcbf --colors -p src tests",
        "test": "phpunit --colors=always",
        "stan": "phpstan analyse",
        "psalm": "psalm --show-info=false"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
